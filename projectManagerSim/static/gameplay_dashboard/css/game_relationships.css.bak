.relationships-container {
    max-width: 1200px;
    margin: 2rem auto;
    padding: 0 2rem;
}

.page-subtitle {
    color: #666;
    font-size: 1rem;
    text-align: center;
    margin-bottom: 2rem;
}

.character-selector {
    background: white;
    border: 2px solid #dee2e6;
    border-radius: 8px;
    padding: 1.5rem;
    margin-bottom: 2rem;
}

.character-selector label {
    font-weight: bold;
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
    display: block;
}

.character-selector select {
    width: 100%;
    padding: 0.75rem;
    font-size: 1rem;
    border: 1px solid #ced4da;
    border-radius: 4px;
    cursor: pointer;
}

.selected-character-info {
    background: #f8f9fa;
    border: 2px solid #dee2e6;
    border-radius: 8px;
    padding: 1.5rem;
    margin-bottom: 2rem;
}

.selected-character-info h2 {
    margin: 0 0 0.5rem 0;
    font-size: 1.5rem;
}

.character-role {
    color: #666;
    font-size: 1rem;
    margin-bottom: 1rem;
}

.character-traits {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
}

.trait-badge {
    background: #007bff;
    color: white;
    padding: 0.25rem 0.75rem;
    border-radius: 4px;
    font-size: 0.85rem;
}

.relationships-section {
    background: white;
    border: 2px solid #dee2e6;
    border-radius: 8px;
    padding: 1.5rem;
    margin-bottom: 2rem;
}

.relationships-section h3 {
    margin: 0 0 1rem 0;
    padding-bottom: 0.75rem;
    border-bottom: 2px solid #dee2e6;
}

.relationship-card {
    background: #f8f9fa;
    border: 1px solid #dee2e6;
    border-radius: 8px;
    padding: 1rem;
    margin-bottom: 1rem;
    transition: all 0.2s ease;
}

.relationship-card:hover {
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
}

.relationship-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.75rem;
}

.relationship-name {
    font-weight: bold;
    font-size: 1.1rem;
}

.badge {
    padding: 0.35rem 0.75rem;
    border-radius: 4px;
    font-size: 0.9rem;
    font-weight: bold;
}

.badge-success {
    background: #28a745;
    color: white;
}

.badge-primary {
    background: #007bff;
    color: white;
}

.badge-secondary {
    background: #6c757d;
    color: white;
}

.badge-warning {
    background: #ffc107;
    color: #333;
}

.badge-danger {
    background: #dc3545;
    color: white;
}

.relationship-details {
    color: #555;
    font-size: 0.95rem;
    line-height: 1.6;
}

.energy-impact {
    margin-top: 0.5rem;
    padding: 0.5rem;
    background: white;
    border-radius: 4px;
    font-weight: bold;
}

.energy-impact.positive {
    color: #28a745;
}

.energy-impact.negative {
    color: #dc3545;
}

.energy-impact.neutral {
    color: #6c757d;
}

.best-partners-section {
    background: white;
    border: 2px solid #dee2e6;
    border-radius: 8px;
    padding: 1.5rem;
}

.best-partners-section h3 {
    margin: 0 0 1rem 0;
    padding-bottom: 0.75rem;
    border-bottom: 2px solid #dee2e6;
}

.partner-card {
    background: #f0f7ff;
    border: 1px solid #007bff;
    border-radius: 8px;
    padding: 1rem;
    margin-bottom: 1rem;
}

.partner-rank {
    font-weight: bold;
    color: #007bff;
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
}

.partner-name {
    font-weight: bold;
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
}

.partner-reasons {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
}

.reason-badge {
    background: white;
    border: 1px solid #007bff;
    color: #007bff;
    padding: 0.25rem 0.75rem;
    border-radius: 4px;
    font-size: 0.85rem;
}

.no-team-message {
    text-align: center;
    padding: 3rem;
    color: #666;
}

.back-link {
    text-align: center;
    margin-top: 2rem;
}

.back-link a {
    color: #007bff;
    text-decoration: none;
    font-size: 1rem;
}

.back-link a:hover {
    text-decoration: underline;
}